/**
 * Find minimum value in array (NEW)
 */
uint16_t findMin(uint16_t* array, int length) {
  uint16_t minVal = 0xFFFF;
  for (int i = 0; i < length; i++) {
    if (array[i] != 0xFFFF && array[i] < minVal) {
      minVal = array[i];
    }
  }
  return minVal;
}

/**
 * Find maximum value in array (NEW)
 */
uint16_t findMax(uint16_t* array, int length) {
  uint16_t maxVal = 0;
  for (int i = 0; i < length; i++) {
    if (array[i] != 0xFFFF && array[i] > maxVal) {
      maxVal = array[i];
    }
  }
  return maxVal;
}

/**
 * Convert AD7280 raw value to voltage (V) (NEW)
 */
float rawToVoltage(uint16_t raw) {
  // AD7280: 12-bit ADC, 1 LSB = 1.22mV for cell voltage channels
  return (raw * 1.22) / 1000.0;
}

/**
 * Convert ADC reading to temperature (Celsius)
 * NOTE: CALIBRATE THIS FOR YOUR SPECIFIC NTC THERMISTORS!
 */
float rawToTemperature(uint16_t raw) {
  // Example for 10k NTC @ 25°C, Beta=3950
  // YOU MUST ADJUST THESE VALUES FOR YOUR THERMISTORS!
  const float VCC = 5.0;
  const float R_SERIES = 10000.0;      // Series resistor value (check schematic)
  const float BETA = 3950.0;           // Beta coefficient (check thermistor datasheet)
  const float R_NOMINAL = 10000.0;     // Resistance at 25°C
  const float T_NOMINAL = 298.15;      // 25°C in Kelvin
  
  float voltage = (raw / 1023.0) * VCC;
  
  // Avoid division by zero
  if (voltage >= VCC || voltage <= 0) {
    return -273.15; // Invalid reading
  }
  
  // Calculate thermistor resistance
  float resistance = (R_SERIES * voltage) / (VCC - voltage);
  
  // Steinhart-Hart simplified (Beta equation)
  float steinhart = log(resistance / R_NOMINAL) / BETA;
  steinhart += 1.0 / T_NOMINAL;
  steinhart = 1.0 / steinhart;
  steinhart -= 273.15; // Convert to Celsius
  
  return steinhart;
}

/**
 * Get minimum cell voltage (NEW)
