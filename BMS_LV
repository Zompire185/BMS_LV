/**
 * Read battery current from A4 (IMON)
 * 
 * Documentation says:
 * "è presente un monitor della corrente che misura in maniera indipendente per 
 *  cortocircuiti o assorbimenti eccessivi"
 * 
 * NOTE: Adjust scaling based on your current sensor IC specifications!
 */
void readCurrent() {
  int raw = analogRead(PIN_CURRENT_MON);
  
  // Example scaling for Hall effect sensor with:
  // - 40mV/A sensitivity
  // - 2.5V zero point (0A)
  // CALIBRATE THIS FOR YOUR ACTUAL SENSOR!
  
  float voltage = (raw / 1023.0) * 5.0;
  batteryCurrent = (voltage - 2.5) / 0.040;  // Positive = discharge, Negative = charge
  
  // Check for overcurrent
  if (batteryCurrent > CURRENT_MAX_DISCHARGE) {
    errorFlags |= ERROR_OVERCURRENT;
    Serial.print(F("⚠ OVERCURRENT (discharge): "));
    Serial.print(batteryCurrent, 1);
    Serial.println(F(" A"));
  }
  
  if (batteryCurrent < CURRENT_MAX_CHARGE) {
    errorFlags |= ERROR_OVERCURRENT;
    Serial.print(F("⚠ OVERCURRENT (charge): "));
    Serial.print(batteryCurrent, 1);
    Serial.println(F(" A"));
  }
}

