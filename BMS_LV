// ============================================================================
// Voltage Monitoring and Open Wire Check
// ============================================================================

/**
 * Read all 8 cell voltages using readall(result[], input).
 * readall() fills one value per chip per call.
 * input 0-3 = cell registers 1-4 on each chip.
 * For 2 chips: buf[0] = chip0 cell(reg), buf[1] = chip1 cell(reg)
 */
void readAllVoltages() 
  {
    unsigned int buf[CHIP_COUNT];

    for (int reg = 0; reg < CELLS_PER_CHIP; reg++) 
      {
        adcStack.readall(buf, reg);
        for (int chip = 0; chip < CHIP_COUNT; chip++) 
          {
            cellVoltages[chip * CELLS_PER_CHIP + reg] = buf[chip];
          }
      }

    // Check system health after read
    if (!adcStack.Run()) 
      {
        errorFlags |= ERROR_SENSOR;
        DEBUG_PRINTLN(F("ERROR: AD7280 Run() = false after voltage read"));
        for (int i = 0; i < TOTAL_CELLS; i++) cellVoltages[i] = 0xFFFF;
      } 
    else 
      {
        DEBUG_PRINTLN(F("Voltages read OK"));
      }
  }

void checkVoltageLimits() 
  {
    for (int i = 0; i < TOTAL_CELLS; i++) 
      {
        if (cellVoltages[i] == 0xFFFF) continue;
        float v = rawToVoltage(cellVoltages[i]);
        if (v > VOLTAGE_MAX) 
          {
            errorFlags |= ERROR_OVERVOLTAGE;
            Serial.print(F("⚠ OVERVOLTAGE Cell ")); Serial.print(i + 1);
            Serial.print(F(": ")); Serial.print(v, 3); Serial.println(F(" V"));
          }
        if (v < VOLTAGE_MIN) 
          {
            errorFlags |= ERROR_UNDERVOLTAGE;
            Serial.print(F("⚠ UNDERVOLTAGE Cell ")); Serial.print(i + 1);
            Serial.print(F(": ")); Serial.print(v, 3); Serial.println(F(" V"));
          }
      }
  }

/**
 * Open wire check - library handles the alternating sigA/sigB pattern.
 * No manual GPIO needed; openwire() does it internally.
 */
void checkOpenWire() 
  {
    adcStack.openwire();
    DEBUG_PRINTLN(F("Open wire check performed"));
  }

// ============================================================================
// Temperature Reading (MULTIPLEXER + analog)
// ============================================================================

void setMuxAddress(uint8_t addr) 
  {
    digitalWrite(PIN_MUX_S0, (addr & 0x01) ? HIGH : LOW);
    digitalWrite(PIN_MUX_S1, (addr & 0x02) ? HIGH : LOW);
    digitalWrite(PIN_MUX_S2, (addr & 0x04) ? HIGH : LOW);
    delay(1); 
  }

/**
 * Read all 24 thermistors via 4x mux (8 addresses × 3 active channels).
 * Sensors are distributed: muxAddr → sensors at idx, idx+8, idx+16.
 * Adjust channel mapping to match actual PCB wiring.
 */
void readAllTemperatures() 
  {
    for (uint8_t muxAddr = 0; muxAddr < 8; muxAddr++) 
      {
        setMuxAddress(muxAddr);

        int idx0 = muxAddr;        // sensors  0-7
        int idx1 = muxAddr + 8;    // sensors  8-15
        int idx2 = muxAddr + 16;   // sensors 16-23
        int idx3 = muxAddr + 24;   // sensors 24-31 (unused, > TOTAL_THERMISTORS)

        if (idx0 < TOTAL_THERMISTORS) cellTemps[idx0] = (uint16_t)analogRead(PIN_TEMP_1A);
        if (idx1 < TOTAL_THERMISTORS) cellTemps[idx1] = (uint16_t)analogRead(PIN_TEMP_2A);
        if (idx2 < TOTAL_THERMISTORS) cellTemps[idx2] = (uint16_t)analogRead(PIN_TEMP_3A);
        if (idx3 < TOTAL_THERMISTORS) cellTemps[idx3] = (uint16_t)analogRead(PIN_TEMP_4A);
      }
    DEBUG_PRINTLN(F("Temperature scan complete"));
  }

void checkTemperatureLimits() 
  {
    for (int i = 0; i < TOTAL_THERMISTORS; i++) 
      {
        if (cellTemps[i] == 0xFFFF) continue;
        float t = rawToTemperature(cellTemps[i]);
        if (t < -50.0f || t > 150.0f) continue;  // sanity check
        if (t > TEMP_MAX) 
          {
            errorFlags |= ERROR_OVERTEMP;
            Serial.print(F("⚠ OVERTEMP Sensor ")); Serial.print(i + 1);
            Serial.print(F(": ")); Serial.print(t, 1); Serial.println(F(" °C"));
          }
        if (t < TEMP_MIN) 
          {
            errorFlags |= ERROR_UNDERTEMP;
            Serial.print(F("⚠ UNDERTEMP Sensor ")); Serial.print(i + 1);
            Serial.print(F(": ")); Serial.print(t, 1); Serial.println(F(" °C"));
          }
      }
  }

// ============================================================================
// Current Monitoring
// ============================================================================

// Sensor calibration: adjust offset (2.5V) and sensitivity (40mV/A) for sensor
void readCurrent() 
  {
    int raw = analogRead(PIN_CURRENT_MON);
    float voltage = (raw / 1023.0f) * 5.0f;
    batteryCurrent = (voltage - 2.5f) / 0.040f;

    if (batteryCurrent > CURRENT_MAX_DISCHARGE) 
      {
        errorFlags |= ERROR_OVERCURRENT;
        Serial.print(F("⚠ OVERCURRENT (discharge): "));
        Serial.print(batteryCurrent, 1); Serial.println(F(" A"));
      }
    if (batteryCurrent < CURRENT_MAX_CHARGE) 
      {
        errorFlags |= ERROR_OVERCURRENT;
        Serial.print(F("⚠ OVERCURRENT (charge): "));
        Serial.print(batteryCurrent, 1); Serial.println(F(" A"));
      }
  }

// ============================================================================
// Cell Balancing 
// ============================================================================

void updateBalancing() 
  {
    if (chargeMode == CHARGE_OFF) 
      {
        for (int chip = 0; chip < CHIP_COUNT; chip++)
          adcStack.balance(chip, false, false, false, false, false, false);
        return;
      }

    uint16_t targetVoltage;
    switch (chargeMode) 
      {
        case CHARGE_FAST:        targetVoltage = VOLTAGE_FAST_CHARGE;   break;
        case CHARGE_NORMAL:      targetVoltage = VOLTAGE_NORMAL_CHARGE; break;
        case CHARGE_MAINTENANCE: targetVoltage = VOLTAGE_FULL_CHARGE;   break;
        case CHARGE_STORAGE:     targetVoltage = VOLTAGE_STORAGE;       break;
        default: return;
      }

    for (int chip = 0; chip < CHIP_COUNT; chip++) 
      {
        bool bal[6] = {false};
        for (int cell = 0; cell < CELLS_PER_CHIP; cell++) 
          {
            int idx = chip * CELLS_PER_CHIP + cell;
            if (cellVoltages[idx] != 0xFFFF)
              bal[cell] = (cellVoltages[idx] >= targetVoltage);
          }
        adcStack.balance(chip, bal[0], bal[1], bal[2], bal[3], bal[4], bal[5]);
      }
  }

void stopBalancing() 
  {
    chargeMode = CHARGE_OFF;
    for (int chip = 0; chip < CHIP_COUNT; chip++)
      adcStack.balance(chip, false, false, false, false, false, false);
    Serial.println(F("Balancing stopped"));
  }

