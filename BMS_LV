/**
 * Control cooling fans via PWM on D3 (PPout)
 * 
 * Documentation says:
 * "ATTENZIONE, la 24V non regolata che alimenta le ventole può raggiungere i 33V 
 *  ed è quindi necessario limitare il duty cycle ad un valore adatto e la frequenza 
 *  abbastanza alta per un controllo sufficiente della potenza"
 * 
 * WARNING: Supply voltage can reach 33V! Limit duty cycle accordingly!
 */
void updateFanControl() {
  float maxTemp = getMaxTemperature();
  
  if (maxTemp < -50.0) {
    // No valid temperature readings
    analogWrite(PIN_POWER_OUT, 0);
    return;
  }
  
  if (maxTemp > TEMP_FAN_START) {
    // Calculate PWM duty cycle (0-255)
    // Limit to ~70% max for 33V compatibility (255 * 0.7 = 178)
    // This gives effective 24V * 0.7 = 16.8V at 24V, or 33V * 0.7 = 23.1V at 33V
    
    float tempRange = TEMP_MAX - TEMP_FAN_START;
    float tempExcess = maxTemp - TEMP_FAN_START;
    
    // Remap temperature to duty cycle
    int dutyCycle = (int)((tempExcess / tempRange) * 178);
    dutyCycle = constrain(dutyCycle, 50, 178); // Min 20%, max 70%
    
    analogWrite(PIN_POWER_OUT, dutyCycle);
    
    DEBUG_PRINT(F("Fan PWM: "));
    DEBUG_PRINT((dutyCycle * 100) / 255);
    DEBUG_PRINT(F("% (Temp: "));
    DEBUG_PRINT(maxTemp, 1);
    DEBUG_PRINTLN(F("°C)"));
  } else {
    // Temperature OK, fans off
    analogWrite(PIN_POWER_OUT, 0);
  }
}

