/**
 * Check temperature limits
 */
void checkTemperatureLimits() {
  for (int i = 0; i < TOTAL_THERMISTORS; i++) {
    if (cellTemps[i] == 0xFFFF) continue;
    
    float t = rawToTemperature(cellTemps[i]);
    
    // Sanity check (thermistor readings should be reasonable)
    if (t < -50.0 || t > 150.0) continue;
    
    if (t > TEMP_MAX) {
      errorFlags |= ERROR_OVERTEMP;
      Serial.print(F("⚠ OVERTEMP Sensor "));
      Serial.print(i + 1);
      Serial.print(F(": "));
      Serial.print(t, 1);
      Serial.println(F(" °C"));
    }
    
    if (t < TEMP_MIN) {
      errorFlags |= ERROR_UNDERTEMP;
      Serial.print(F("⚠ UNDERTEMP Sensor "));
      Serial.print(i + 1);
      Serial.print(F(": "));
      Serial.print(t, 1);
      Serial.println(F(" °C"));
    }
  }
}

