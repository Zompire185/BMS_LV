// ============================================================================
// Error Handling 
// ============================================================================

void assertError() 
{
    digitalWrite(PIN_ERROR_MCU, HIGH);
    Serial.print(F("\n ERROR FLAGS: 0x")); Serial.println(errorFlags, HEX);
    if (errorFlags & ERROR_OVERVOLTAGE)   Serial.println(F("  • OVERVOLTAGE"));
    if (errorFlags & ERROR_UNDERVOLTAGE)  Serial.println(F("  • UNDERVOLTAGE"));
    if (errorFlags & ERROR_OVERTEMP)      Serial.println(F("  • OVERTEMPERATURE"));
    if (errorFlags & ERROR_UNDERTEMP)     Serial.println(F("  • UNDERTEMPERATURE"));
    if (errorFlags & ERROR_OVERCURRENT)   Serial.println(F("  • OVERCURRENT"));
    if (errorFlags & ERROR_OPEN_WIRE)     Serial.println(F("  • OPEN WIRE"));
    if (errorFlags & ERROR_SENSOR)        Serial.println(F("  • SENSOR ERROR"));
    if (errorFlags & ERROR_COMMUNICATION) Serial.println(F("  • COMMUNICATION ERROR"));
    Serial.println();
  }

void clearErrors() 
  {
    errorFlags = ERROR_NONE;
    digitalWrite(PIN_ERROR_MCU, LOW);
    Serial.println(F("✓ Errors cleared"));
  }

void emergencyShutdown() 
  {
    Serial.println(F("\n     EMERGENCY SHUTDOWN"));
    Serial.println(F("   Critical error detected"));
    Serial.println(F("  Entering safe mode - power cycle to restart"));
    delay(10);  

    for (int chip = 0; chip < CHIP_COUNT; chip++)
      adcStack.balance(chip, false, false, false, false, false, false);

    analogWrite(PIN_POWER_OUT, 0);
    digitalWrite(PIN_ERROR_MCU, HIGH);
    delay(100);

    wdt_disable();
    sleep_enable();
    set_sleep_mode(SLEEP_MODE_PWR_DOWN);
    sleep_cpu();
    // Never returns — requires power cycle
  }

// ============================================================================
// Safety Check
// ============================================================================

/**
 * IMPORTANT: selfTest() returns TRUE on error, FALSE when healthy.
 * Run() returns true when system is OK.
 */
bool performSafetyCheck() 
  {
    bool safe = true;

    if (adcStack.selfTest()) 
      {           // TRUE = error!
        errorFlags |= ERROR_SENSOR;
        safe = false;
        Serial.println(F("⚠ AD7280 self-test failed"));
      } 
      else 
        {
        DEBUG_PRINTLN(F("✓ AD7280 self-test OK"));
        }

    if (!adcStack.Run()) 
      {               // FALSE = error
        errorFlags |= ERROR_COMMUNICATION;
        safe = false;
        Serial.println(F("⚠ AD7280 not running (go=false)"));
      }

    return safe;
  }

// ============================================================================
// Serial Reporting 
// ============================================================================

void printDataReport() 
  {
    Serial.println(F("      BMS LV - System Status Report"));

    //  Cell Voltages 
    float totalVoltage = 0.0f;
    int   validCells   = 0;

    Serial.println(F("\n┌─── Cell Voltages ───────────────────────────────┐"));
    for (int i = 0; i < TOTAL_CELLS; i++) 
      {
        Serial.print(F("│ Cell "));
        if (i < 9) Serial.print(F(" "));
        Serial.print(i + 1); Serial.print(F(": "));
        if (cellVoltages[i] != 0xFFFF) 
          {
            float v = rawToVoltage(cellVoltages[i]);
            Serial.print(v, 3); Serial.print(F(" V"));
            if      (v > VOLTAGE_MAX) Serial.print(F("   HIGH"));
            else if (v < VOLTAGE_MIN) Serial.print(F("   LOW "));
            else                       Serial.print(F("  ✓    "));
            totalVoltage += v; validCells++;
          } 
          else 
            { Serial.print(F("   ERROR   ✗")); }
        for (int j = 0; j < 17; j++) Serial.print(F(" "));
        Serial.println(F("│"));
      }
    Serial.println(F("├──────────────────────────────────────────────────┤"));
    Serial.print(F("│ Pack:    ")); Serial.print(totalVoltage, 2);
    Serial.print(F(" V  (")); Serial.print(validCells);
    Serial.print(F("/")); Serial.print(TOTAL_CELLS); Serial.println(F(" cells valid)        │"));
    Serial.print(F("│ Min:     ")); Serial.print(getMinVoltage(), 3); Serial.println(F(" V                               │"));
    Serial.print(F("│ Max:     ")); Serial.print(getMaxVoltage(), 3); Serial.println(F(" V                               │"));
    Serial.print(F("│ Delta:   ")); Serial.print((getMaxVoltage() - getMinVoltage()) * 1000.0f, 1);
    Serial.println(F(" mV                             │"));
    Serial.println(F("└──────────────────────────────────────────────────┘"));

    //  Temperatures 
    float avgTemp    = 0.0f;
    int   validTemps = 0;

    Serial.println(F("\n┌─── Temperatures (first 8 shown) ───────────────┐"));
    for (int i = 0; i < min(8, TOTAL_THERMISTORS); i++) 
      {
        Serial.print(F("│ Sensor "));
        if (i < 9) Serial.print(F(" "));
        Serial.print(i + 1); Serial.print(F(": "));
        if (cellTemps[i] != 0xFFFF) 
          {
            float t = rawToTemperature(cellTemps[i]);
            if (t > -50.0f && t < 150.0f)
              {
                Serial.print(t, 1); Serial.print(F(" °C"));
                if      (t > TEMP_MAX)     Serial.print(F("   HOT "));
                else if (t > TEMP_WARNING) Serial.print(F("   WARM"));
                else if (t < TEMP_MIN)     Serial.print(F("   COLD"));
                else                        Serial.print(F("  ✓    "));
                avgTemp += t; validTemps++;
              } 
              else { Serial.print(F("INVALID       ")); }
          } 
          else { Serial.print(F("ERROR   ✗     ")); }
          for (int j = 0; j < 17; j++) Serial.print(F(" "));
        Serial.println(F("│"));
      }
    if (TOTAL_THERMISTORS > 8)
      {
        Serial.print(F("│ ... (")); Serial.print(TOTAL_THERMISTORS - 8);
        Serial.println(F(" more sensors not shown)               │"));
      }
    Serial.println(F("├──────────────────────────────────────────────────┤"));
    if (validTemps > 0) 
      {
        Serial.print(F("│ Average: ")); Serial.print(avgTemp / validTemps, 1);
        Serial.println(F(" °C                              │"));
      }
    float maxT = getMaxTemperature();
    Serial.print(F("│ Maximum: "));
    if (maxT > -50.0f) { Serial.print(maxT, 1); Serial.println(F(" °C                              │")); }
    else                { Serial.println(F("N/A                                  │")); }
    Serial.println(F("└──────────────────────────────────────────────────┘"));

    //  Current 
    Serial.println(F("\n┌─── Current ─────────────────────────────────────┐"));
    Serial.print(F("│ Current: ")); Serial.print(batteryCurrent, 2); Serial.print(F(" A  "));
    if      (batteryCurrent >  1.0f) Serial.print(F("(Discharging)  "));
    else if (batteryCurrent < -1.0f) Serial.print(F("(Charging)     "));
    else                              Serial.print(F("(Idle)         "));
    Serial.println(F("         │"));
    Serial.print(F("│ Power:   ")); Serial.print((totalVoltage * batteryCurrent) / 1000.0f, 2);
    Serial.println(F(" kW                            │"));
    Serial.println(F("└──────────────────────────────────────────────────┘"));

    //  Status 
    Serial.println(F("\n┌─── System Status ───────────────────────────────┐"));
    Serial.print(F("│ Mode:    "));
    switch (chargeMode) 
      {
        case CHARGE_OFF:         Serial.println(F("OFF                              │")); break;
        case CHARGE_FAST:        Serial.println(F("FAST CHARGE     (3.8V target)    │")); break;
        case CHARGE_NORMAL:      Serial.println(F("NORMAL CHARGE   (4.0V target)    │")); break;
        case CHARGE_MAINTENANCE: Serial.println(F("MAINTENANCE     (4.126V target)  │")); break;
        case CHARGE_STORAGE:     Serial.println(F("STORAGE MODE    (3.5V target)    │")); break;
      }
    Serial.print(F("│ Errors:  0x"));
    if (errorFlags < 0x10) Serial.print(F("0"));
    Serial.print(errorFlags, HEX); Serial.print(F("  "));
    if (errorFlags == ERROR_NONE) 
      {
        Serial.println(F("✓ ALL OK                     │"));
      } 
    else 
      {
          Serial.println(F("⚠ ERRORS PRESENT             │"));
          if (errorFlags & ERROR_OVERVOLTAGE)   Serial.println(F("│   • Overvoltage                                  │"));
          if (errorFlags & ERROR_UNDERVOLTAGE)  Serial.println(F("│   • Undervoltage                                 │"));
          if (errorFlags & ERROR_OVERTEMP)      Serial.println(F("│   • Over-temperature                             │"));
          if (errorFlags & ERROR_UNDERTEMP)     Serial.println(F("│   • Under-temperature                            │"));
          if (errorFlags & ERROR_OVERCURRENT)   Serial.println(F("│   • Overcurrent                                  │"));
          if (errorFlags & ERROR_OPEN_WIRE)     Serial.println(F("│   • Open wire detected                           │"));
          if (errorFlags & ERROR_SENSOR)        Serial.println(F("│   • Sensor error                                 │"));
          if (errorFlags & ERROR_COMMUNICATION) Serial.println(F("│   • Communication error                          │"));
        }
    Serial.println(F("└──────────────────────────────────────────────────┘\n"));
  }

// ============================================================================
// Serial Commands
// ============================================================================

void printHelp() 
  {
    Serial.println(F("\n Commands:"));
    Serial.println(F("  V - Full status report"));
    Serial.println(F("  F - Fast charge mode    (3.8V)"));
    Serial.println(F("  N - Normal charge mode  (4.0V)"));
    Serial.println(F("  B - Maintenance balance (4.126V)"));
    Serial.println(F("  T - Storage mode        (3.5V)"));
    Serial.println(F("  S - Stop balancing"));
    Serial.println(F("  R - Reset error flags"));
    Serial.println(F("  O - Trigger open wire check"));
    Serial.println(F("  H - This help message\n"));
  }

void processSerialCommands() 
  {
    if (!Serial.available()) return;
    char cmd = Serial.read();
    while (Serial.available()) { Serial.read(); delay(1); }

    switch (cmd) 
      {
        case 'v': case 'V': printDataReport(); break;
        case 'f': case 'F': chargeMode = CHARGE_FAST;        Serial.println(F("✓ Fast charge mode")); break;
        case 'n': case 'N': chargeMode = CHARGE_NORMAL;      Serial.println(F("✓ Normal charge mode")); break;
        case 'b': case 'B': chargeMode = CHARGE_MAINTENANCE; Serial.println(F("✓ Maintenance balance mode")); break;
        case 't': case 'T': chargeMode = CHARGE_STORAGE;     Serial.println(F("✓ Storage mode")); break;
        case 's': case 'S': stopBalancing(); break;
        case 'r': case 'R': clearErrors(); break;
        case 'o': case 'O': checkOpenWire(); Serial.println(F("✓ Open wire check done")); break;
        case 'h': case 'H': case '?': printHelp(); break;
        case '\n': case '\r': break;
        default:
          Serial.print(F("Unknown command '")); Serial.print(cmd);
          Serial.println(F("' - type H for help"));
          break;
      }
  }

// ============================================================================
// Setup
// ============================================================================

void setup() 
  {
    Serial.begin(9600);
    unsigned long t0 = millis();
    while (!Serial && (millis() - t0 < 3000)) delay(10);

    Serial.println(F("\n╔═════════════════════════════════════════════════╗"));
    Serial.println(F("║    Formula SAE - BMS LV Controller  v3.2          ║"));
    Serial.println(F("║          8s12p Lithium-ion Pack                   ║"));
    Serial.println(F("╚═══════════════════════════════════════════════════╝\n"));

    // Pin setup 
    pinMode(PIN_POWER_OUT,   OUTPUT);
    pinMode(PIN_ERROR_MCU,   OUTPUT);
    pinMode(PIN_OPEN_WIRE_A, OUTPUT);
    pinMode(PIN_OPEN_WIRE_B, OUTPUT);
    pinMode(PIN_MUX_S0,      OUTPUT);
    pinMode(PIN_MUX_S1,      OUTPUT);
    pinMode(PIN_MUX_S2,      OUTPUT);

    digitalWrite(PIN_POWER_OUT,   LOW);
    digitalWrite(PIN_ERROR_MCU,   LOW);
    digitalWrite(PIN_OPEN_WIRE_A, LOW);
    digitalWrite(PIN_OPEN_WIRE_B, LOW);
    Serial.println(F("✓ I/O configured"));

    //  Initialize arrays (0xFFFF) 
    for (int i = 0; i < TOTAL_CELLS;       i++) cellVoltages[i] = 0xFFFF;
    for (int i = 0; i < TOTAL_THERMISTORS; i++) cellTemps[i]    = 0xFFFF;
    Serial.println(F("✓ Arrays initialized"));

    //  AD7280 init 
    Serial.print(F("Starting AD7280 ("));
    Serial.print(CHIP_COUNT); Serial.print(F(" chips, "));
    Serial.print(TOTAL_CELLS); Serial.print(F(" cells)... "));

    systemOK = adcStack.begin();

    if (!systemOK) 
      {
        Serial.println(F("FAILED"));
        Serial.println(F("Check SPI wiring and AD7280 power supply."));
        errorFlags |= ERROR_SENSOR;
        digitalWrite(PIN_ERROR_MCU, HIGH);
        while (1) 
          {
            delay(3000);
            Serial.println(F(">>> HALTED: AD7280 init failed. Power cycle to retry. <<<"));
          }
      }
    Serial.println(F("OK ✓"));

    //  Set hardware alert thresholds 
    if (adcStack.threshold(ADC_VLOW, ADC_VHIGH, ADC_TLOW, ADC_THIGH)) 
      {
        Serial.println(F("✓ Thresholds set"));
      } 
    else 
      {
        Serial.println(F("⚠ Threshold set failed - software monitoring active"));
      }

    //  Self-test: TRUE = error, FALSE = OK 
    if (adcStack.selfTest()) 
      {
        Serial.println(F("⚠ AD7280 self-test failed - proceeding with caution"));
        errorFlags |= ERROR_SENSOR;
      } 
    else 
      {
        Serial.println(F("✓ Self-test passed"));
      }

    //  Watchdog 
    wdt_enable(WDTO_8S);
    Serial.println(F("✓ Watchdog enabled (8s)"));

    //  Initial readings 
    delay(100);
    readAllVoltages();
    readAllTemperatures();
    readCurrent();
    Serial.println(F("✓ Initial readings done"));

    //  Seed timers 
    unsigned long now   = millis();
    lastConversionTime  = now;
    lastTempTime        = now;
    lastOpenWireTime    = now;
    lastReportTime      = now;
    lastSafetyCheckTime = now;

    Serial.println(F("\n╔═════════════════════════════════════════════════╗"));
    Serial.println(F("║         ✓ BMS LV Ready  - Monitoring Active       ║"));
    Serial.println(F("╚═══════════════════════════════════════════════════╝"));
    Serial.println(F("Type H for commands, V for status report\n"));
    printDataReport();
  }

// ============================================================================
// Main Loop
// ============================================================================

void loop() 
  {
    wdt_reset();
    unsigned long now = millis();

    // 1. Voltage read + limit check (every 100ms)
    if (now - lastConversionTime >= CONVERSION_INTERVAL) 
      {
        lastConversionTime = now;
        readAllVoltages();
        checkVoltageLimits();
      }

    // 2. Temperature read + limit check + fan update (every 500ms)
    if (now - lastTempTime >= TEMP_READ_INTERVAL) 
      {
        lastTempTime = now;
        readAllTemperatures();
        checkTemperatureLimits();
       // updateFanControl();
      }

    // 3. Current read (every cycle)
    readCurrent();

    // 4. Open wire check (every 5s)
    if (now - lastOpenWireTime >= OPEN_WIRE_INTERVAL) 
      {
        lastOpenWireTime = now;
        checkOpenWire();
      }

    // 5. Cell balancing update
    updateBalancing();

    // 6. Periodic safety check (every 10s)
    if (now - lastSafetyCheckTime >= SAFETY_CHECK_INTERVAL) 
      {
        lastSafetyCheckTime = now;
        performSafetyCheck();
      }

    // 7. Error assertion + critical shutdown
    if (errorFlags != ERROR_NONE) 
      {
        assertError();
        if (errorFlags & (ERROR_OVERVOLTAGE | ERROR_OVERCURRENT | ERROR_OVERTEMP))
          emergencyShutdown();  // does not return
      } 
    else 
      {
        digitalWrite(PIN_ERROR_MCU, LOW);
      }

    // 8. Auto serial report (every 1s)
    if (now - lastReportTime >= SERIAL_REPORT_INTERVAL) 
      {
        lastReportTime = now;
        printDataReport();
      }

    // 9. Serial command handler
    processSerialCommands();

    delay(10);
  }
