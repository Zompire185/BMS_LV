/* OLD: startBalancing() function - complex logic with multiple modes */

/**
 * Activate cell balancing based on charge mode
 * 
 * Documentation says:
 * "quando il segnale indica la presenza di una corrente notevolmente negativa, 
 *  si entra in modalità ricarica dov'è necessario bilanciare le celle al termine 
 *  della carica"
 * 
 * NEW: Simplified and clearer implementation
 */
void updateBalancing() {
  if (chargeMode == CHARGE_OFF) {
    // Stop all balancing
    for (int chip = 0; chip < CHIP_COUNT; chip++) {
      adcStack.balance(chip, false, false, false, false, false, false);
    }
    DEBUG_PRINTLN(F("Balancing disabled"));
    return;
  }
  
  // Determine target voltage based on mode
  uint16_t targetVoltage;
  switch (chargeMode) {
    case CHARGE_FAST:
      targetVoltage = VOLTAGE_FAST_CHARGE;       // 3.8V
      DEBUG_PRINTLN(F("Balancing: Fast charge mode (3.8V)"));
      break;
    case CHARGE_NORMAL:
      targetVoltage = VOLTAGE_NORMAL_CHARGE;     // 4.0V
      DEBUG_PRINTLN(F("Balancing: Normal charge mode (4.0V)"));
      break;
    case CHARGE_MAINTENANCE:
      targetVoltage = VOLTAGE_FULL_CHARGE;       // 4.126V
      DEBUG_PRINTLN(F("Balancing: Maintenance mode (4.126V)"));
      break;
    case CHARGE_STORAGE:
      targetVoltage = VOLTAGE_STORAGE;           // 3.5V
      DEBUG_PRINTLN(F("Balancing: Storage mode (3.5V)"));
      break;
    default:
      return;
  }
  
  // Balance cells above target voltage
  for (int chip = 0; chip < CHIP_COUNT; chip++) {
    bool balance[6] = {false}; // AD7280 supports 6 cells (we use 4)
    
    for (int cell = 0; cell < CELLS_PER_CHIP; cell++) {
      int globalIdx = chip * CELLS_PER_CHIP + cell;
      
      if (cellVoltages[globalIdx] != 0xFFFF) {
        balance[cell] = (cellVoltages[globalIdx] >= targetVoltage);
        
        if (balance[cell]) {
          DEBUG_PRINT(F("Balancing cell "));
          DEBUG_PRINTLN(globalIdx + 1);
        }
      }
    }
    
    adcStack.balance(chip, balance[0], balance[1], balance[2], 
                     balance[3], balance[4], balance[5]);
  }
}

