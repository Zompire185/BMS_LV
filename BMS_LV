/**
 * Process commands from serial port (NEW)
 * Allows control and inspection via laptop
 */
void processSerialCommands() {
  if (Serial.available() > 0) {
    char cmd = Serial.read();
    
    // Clear any extra characters
    while (Serial.available() > 0) {
      Serial.read();
      delay(1);
    }
    
    switch (cmd) {
      case 'v':
      case 'V':
        // Print full report
        printDataReport();
        break;
        
      case 'b':
      case 'B':
        // Start balancing (maintenance mode)
        chargeMode = CHARGE_MAINTENANCE;
        Serial.println(F("✓ Balancing activated (Maintenance mode)"));
        break;
        
      case 's':
      case 'S':
        // Stop balancing
        stopBalancing();
        break;
        
      case 'f':
      case 'F':
        // Fast charge mode
        chargeMode = CHARGE_FAST;
        Serial.println(F("✓ Fast charge mode activated"));
        break;
        
      case 'n':
      case 'N':
        // Normal charge mode
        chargeMode = CHARGE_NORMAL;
        Serial.println(F("✓ Normal charge mode activated"));
        break;
        
      case 't':
      case 'T':
        // Storage mode
        chargeMode = CHARGE_STORAGE;
        Serial.println(F("✓ Storage mode activated"));
        break;
        
      case 'r':
      case 'R':
        // Reset errors
        clearErrors();
        break;
        
      case 'o':
      case 'O':
        // Perform open wire check
        Serial.println(F("Performing open wire check..."));
        checkOpenWire();
        Serial.println(F("✓ Open wire check complete"));
        break;
        
      case 'h':
      case 'H':
      case '?':
        // Help
        Serial.println(F("\n╔════════════════════════════════════════════════════╗"));
        Serial.println(F("║              BMS LV Command Reference            ║"));
        Serial.println(F("╚════════════════════════════════════════════════════╝"));
        Serial.println(F("\nData & Monitoring:"));
        Serial.println(F("  V - Print full system status report"));
        Serial.println(F("\nCharge Control:"));
        Serial.println(F("  F - Fast charge mode (3.8V)"));
        Serial.println(F("  N - Normal charge mode (4.0V)"));
        Serial.println(F("  B - Balance/Maintenance mode (4.126V)"));
        Serial.println(F("  T - Storage mode (3.5V)"));
        Serial.println(F("  S - Stop all charging/balancing"));
        Serial.println(F("\nDiagnostics:"));
        Serial.println(F("  O - Perform open wire check"));
        Serial.println(F("  R - Reset error flags"));
        Serial.println(F("  H - This help menu"));
        Serial.println();
        break;
        
      case '\n':
      case '\r':
        // Ignore newlines
        break;
        
      default:
        Serial.print(F("Unknown command: "));
        Serial.println(cmd);
        Serial.println(F("Type 'H' for help"));
        break;
    }
  }
}

