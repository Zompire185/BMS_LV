/**
 * Check voltage limits and set error flags
 */
void checkVoltageLimits() {
  for (int i = 0; i < TOTAL_CELLS; i++) {
    if (cellVoltages[i] == 0xFFFF) continue; // Skip invalid readings
    
    float v = rawToVoltage(cellVoltages[i]);
    
    if (v > VOLTAGE_MAX) {
      errorFlags |= ERROR_OVERVOLTAGE;
      Serial.print(F("⚠ OVERVOLTAGE Cell "));
      Serial.print(i + 1);
      Serial.print(F(": "));
      Serial.print(v, 3);
      Serial.println(F(" V"));
    }
    
    if (v < VOLTAGE_MIN) {
      errorFlags |= ERROR_UNDERVOLTAGE;
      Serial.print(F("⚠ UNDERVOLTAGE Cell "));
      Serial.print(i + 1);
      Serial.print(F(": "));
      Serial.print(v, 3);
      Serial.println(F(" V"));
    }
  }
}

/**
 * Perform open wire detection
 * Toggle sigA and sigB alternately to force open wire detection in AD7280
 * 
 * Documentation says:
 * "è necessario agire occasionalmente in maniera alternativa sui segnali A e B 
 *  per forzare il rilevamento della rottura di un filo"
 */
void checkOpenWire() {
  // Pulse pattern A
  digitalWrite(PIN_OPEN_WIRE_A, HIGH);
  digitalWrite(PIN_OPEN_WIRE_B, LOW);
  delay(10);
  
  // Pulse pattern B
  digitalWrite(PIN_OPEN_WIRE_A, LOW);
  digitalWrite(PIN_OPEN_WIRE_B, HIGH);
  delay(10);
  
  // Reset both low
  digitalWrite(PIN_OPEN_WIRE_A, LOW);
  digitalWrite(PIN_OPEN_WIRE_B, LOW);
  
  // AD7280 will automatically flag open wire conditions in status registers
  DEBUG_PRINTLN(F("Open wire check performed"));
}

