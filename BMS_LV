  Serial.println(F(" mV                          │"));
  
  Serial.println(F("└──────────────────────────────────────────────────┘"));
  
  // === TEMPERATURES ===
  Serial.println(F("\n┌─── Temperatures ────────────────────────────────┐"));
  
