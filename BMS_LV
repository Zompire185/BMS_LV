}

/**
 * Get maximum cell voltage (NEW)
 */
float getMaxVoltage() {
  uint16_t maxRaw = findMax(cellVoltages, TOTAL_CELLS);
  if (maxRaw == 0) return 0.0;
  return rawToVoltage(maxRaw);
}

/**
 * Get maximum temperature (NEW)
 */
float getMaxTemperature() {
  float maxT = -273.15;
  for (int i = 0; i < TOTAL_THERMISTORS; i++) {
    if (cellTemps[i] != 0xFFFF) {
      float t = rawToTemperature(cellTemps[i]);
      if (t > maxT && t < 150.0) {  // Sanity check
        maxT = t;
      }
    }
  }
  return maxT;
}

// ============================================================================
// RING BUFFER FUNCTIONS (for future bus communication)
// ============================================================================

bool bufferIsEmpty() {
  return bufferHead == bufferTail;
}

bool bufferIsFull() {
  return ((bufferHead + 1) % BUFFER_SIZE) == bufferTail;
}

void bufferPush(uint8_t data) {
  uint8_t next = (bufferHead + 1) % BUFFER_SIZE;
  if (next != bufferTail) {
    ringBuffer[bufferHead] = data;
    bufferHead = next;
  }
}

int bufferPop() {
  if (bufferIsEmpty()) return -1;
  
  uint8_t data = ringBuffer[bufferTail];
  bufferTail = (bufferTail + 1) % BUFFER_SIZE;
  return data;
}

bool peekPacket(uint32_t* packetOut) {
  uint8_t available = (bufferHead - bufferTail + BUFFER_SIZE) % BUFFER_SIZE;
  if (available < 4) return false;
  
  uint8_t b1 = ringBuffer[bufferTail];
  uint8_t b2 = ringBuffer[(bufferTail + 1) % BUFFER_SIZE];
  uint8_t b3 = ringBuffer[(bufferTail + 2) % BUFFER_SIZE];
  uint8_t b4 = ringBuffer[(bufferTail + 3) % BUFFER_SIZE];
  
  *packetOut = ((uint32_t)b1 << 24) | ((uint32_t)b2 << 16) | ((uint32_t)b3 << 8) | b4;
  
  bufferTail = (bufferTail + 1) % BUFFER_SIZE;
  return true;
}

