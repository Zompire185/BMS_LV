  Serial.print(F("\n⚠⚠⚠ ERROR FLAGS ACTIVE: 0x"));
  Serial.print(errorFlags, HEX);
  Serial.println(F(" ⚠⚠⚠"));
  
  if (errorFlags & ERROR_OVERVOLTAGE) Serial.println(F("  • OVERVOLTAGE"));
  if (errorFlags & ERROR_UNDERVOLTAGE) Serial.println(F("  • UNDERVOLTAGE"));
  if (errorFlags & ERROR_OVERTEMP) Serial.println(F("  • OVERTEMPERATURE"));
  if (errorFlags & ERROR_UNDERTEMP) Serial.println(F("  • UNDERTEMPERATURE"));
  if (errorFlags & ERROR_OVERCURRENT) Serial.println(F("  • OVERCURRENT"));
  if (errorFlags & ERROR_OPEN_WIRE) Serial.println(F("  • OPEN WIRE"));
  if (errorFlags & ERROR_SENSOR) Serial.println(F("  • SENSOR ERROR"));
  if (errorFlags & ERROR_COMMUNICATION) Serial.println(F("  • COMMUNICATION ERROR"));
  Serial.println();
}

