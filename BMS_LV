/**
 * Emergency shutdown (NEW: improved with more feedback)
 */
void emergencyShutdown() {
  Serial.println(F("\n"));
  Serial.println(F("╔════════════════════════════════════╗"));
  Serial.println(F("║  !!! EMERGENCY SHUTDOWN !!!       ║"));
  Serial.println(F("║  Critical error detected          ║"));
  Serial.println(F("║  System entering safe mode        ║"));
  Serial.println(F("╚════════════════════════════════════╝"));
  Serial.println();
  
  // Stop all balancing
  for (int chip = 0; chip < CHIP_COUNT; chip++) {
    adcStack.balance(chip, false, false, false, false, false, false);
  }
  
  // Turn off power output
  digitalWrite(PIN_POWER_OUT, LOW);
  
  // Assert error signal
  digitalWrite(PIN_ERROR_MCU, HIGH);
  
  // Small delay to ensure serial is flushed
  delay(100);
  
  // Enter low power mode (requires power cycle to restart)
  wdt_disable();
  sleep_enable();
  set_sleep_mode(SLEEP_MODE_PWR_DOWN);
  sleep_cpu();
  
  // Will never reach here unless external wake-up
}

