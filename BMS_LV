/**
 * Set multiplexer address (3-bit: 0-7)
 * Each address selects a group of thermistors
 */
void setMuxAddress(uint8_t addr) {
  digitalWrite(PIN_MUX_S0, (addr & 0x01) ? HIGH : LOW);
  digitalWrite(PIN_MUX_S1, (addr & 0x02) ? HIGH : LOW);
  digitalWrite(PIN_MUX_S2, (addr & 0x04) ? HIGH : LOW);
  delay(1); // Allow mux to settle (as recommended in documentation)
}

/**
 * Read all temperature sensors via multiplexers
 * 
 * Architecture: 8 mux addresses × 4 analog inputs = 32 possible sensors
 * We use 24 sensors for 8s pack (3 sensors per cell = 37.5% coverage)
 * 
 * Documentation says:
 * "usando le 3 linee di indirizzo per selezionare tra 8 possibili gruppi di 6 
 *  termistori sequenziali (ADD=000->T0,T6,T12,T18 ADD=001->T1,T7,T13,T...)"
 * 
 * NEW: Proper multiplexer scanning implementation
 */
void readAllTemperatures() {
  for (uint8_t muxAddr = 0; muxAddr < 8; muxAddr++) {
    setMuxAddress(muxAddr);
    
    // Read 4 analog channels for this mux address
    // Map sensors across addresses to distribute them
    // Adjust indices based on actual PCB wiring
    
    int idx0 = muxAddr;              // 0,1,2,3,4,5,6,7
    int idx1 = muxAddr + 8;          // 8,9,10,11,12,13,14,15
    int idx2 = muxAddr + 16;         // 16,17,18,19,20,21,22,23
    int idx3 = muxAddr + 24;         // 24,25,26,27,28,29,30,31
    
    if (idx0 < TOTAL_THERMISTORS) {
      cellTemps[idx0] = analogRead(PIN_TEMP_1A);
    }
    if (idx1 < TOTAL_THERMISTORS) {
      cellTemps[idx1] = analogRead(PIN_TEMP_2A);
    }
    if (idx2 < TOTAL_THERMISTORS) {
      cellTemps[idx2] = analogRead(PIN_TEMP_3A);
    }
    if (idx3 < TOTAL_THERMISTORS) {
      cellTemps[idx3] = analogRead(PIN_TEMP_4A);
    }
  }
  
  DEBUG_PRINTLN(F("Temperature scan complete"));
}

