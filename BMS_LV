// ============================================================================
// Utility Functions 
// ============================================================================

uint16_t findMin(uint16_t* array, int length) 
  {
    uint16_t minVal = 0xFFFF;
    for (int i = 0; i < length; i++)
      if (array[i] != 0xFFFF && array[i] < minVal) minVal = array[i];
    return minVal;
  }

uint16_t findMax(uint16_t* array, int length) 
  {
    uint16_t maxVal = 0;
    for (int i = 0; i < length; i++)
      if (array[i] != 0xFFFF && array[i] > maxVal) maxVal = array[i];
    return maxVal;
  }

// AD7280: 1 LSB = 1.22mV for cell voltage channels
float rawToVoltage(uint16_t raw) 
  {
    return (raw * 1.22f) / 1000.0f;
  }

// Calibration: adjust R_SERIES, BETA, R_NOMINAL to match actual NTC thermistors
float rawToTemperature(uint16_t raw) 
  {
    const float VCC       = 5.0f;
    const float R_SERIES  = 10000.0f;  // series resistor on PCB
    const float BETA      = 3950.0f;   // NTC beta coefficient
    const float R_NOMINAL = 10000.0f;  // NTC resistance at 25°C
    const float T_NOMINAL = 298.15f;   // 25°C in Kelvin

    float voltage = (raw / 1023.0f) * VCC;
    if (voltage >= VCC || voltage <= 0.0f) return -273.15f;

    float resistance = (R_SERIES * voltage) / (VCC - voltage);
    float steinhart  = logf(resistance / R_NOMINAL) / BETA;
    steinhart += 1.0f / T_NOMINAL;
    steinhart  = 1.0f / steinhart;
    steinhart -= 273.15f;
    return steinhart;
  }

float getMinVoltage() 
  {
    uint16_t r = findMin(cellVoltages, TOTAL_CELLS);
    return (r == 0xFFFF) ? 0.0f : rawToVoltage(r);
  }

float getMaxVoltage() 
  {
    uint16_t r = findMax(cellVoltages, TOTAL_CELLS);
    return (r == 0) ? 0.0f : rawToVoltage(r);
  }

float getMaxTemperature() 
  {
    float maxT = -273.15f;
    for (int i = 0; i < TOTAL_THERMISTORS; i++) 
      {
        if (cellTemps[i] == 0xFFFF) continue;
        float t = rawToTemperature(cellTemps[i]);
        if (t > maxT && t < 150.0f) maxT = t;
      }
    return maxT;
  }

