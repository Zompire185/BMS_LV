/**
 * Perform comprehensive safety check (NEW)
 */
bool performSafetyCheck() {
  bool safe = true;
  
  // Check AD7280 self-test
  if (!adcStack.selfTest()) {
    errorFlags |= ERROR_SENSOR;
    safe = false;
    Serial.println(F("⚠ AD7280 self-test failed"));
  }
  
  // Check ACK from AD7280
  if (!adcStack.ackvar) {
    errorFlags |= ERROR_COMMUNICATION;
    safe = false;
    Serial.println(F("⚠ AD7280 ACK not received"));
  }
  
  // Critical errors require immediate shutdown
  if (errorFlags & (ERROR_OVERVOLTAGE | ERROR_OVERCURRENT | ERROR_OVERTEMP)) {
    Serial.println(F("⚠ CRITICAL ERROR DETECTED - INITIATING SHUTDOWN"));
    safe = false;
  }
  
  return safe;
}

