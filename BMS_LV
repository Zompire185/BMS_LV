// ============================================================================
// MAIN LOOP
// ============================================================================

void loop() {
  // Pet the watchdog (prevent system reset)
  wdt_reset();
  
  unsigned long now = millis();
  
  // === AD7280 VOLTAGE CONVERSIONS (100ms interval) ===
  if (now - lastConversionTime >= CONVERSION_INTERVAL) {
    if (readVoltages) {
      readAllVoltages();
      checkVoltageLimits();
    }
    // Alternate between voltage and aux readings for efficiency
    readVoltages = !readVoltages;
    lastConversionTime = now;
  }
  
  // === TEMPERATURE READINGS (500ms interval) ===
  if (now - lastTempTime >= TEMP_READ_INTERVAL) {
    readAllTemperatures();
    checkTemperatureLimits();
    updateFanControl();
    lastTempTime = now;
  }
  
  // === OPEN WIRE CHECK (5s interval) ===
  if (now - lastOpenWireTime >= OPEN_WIRE_INTERVAL) {
    checkOpenWire();
    lastOpenWireTime = now;
  }
  
  // === CURRENT MONITORING (every loop) ===
  readCurrent();
  
  // === BALANCING UPDATE ===
  updateBalancing();
  
  // === SAFETY CHECK ===
  if (!performSafetyCheck()) {
    // Critical error detected
    if (errorFlags & (ERROR_OVERVOLTAGE | ERROR_OVERCURRENT | ERROR_OVERTEMP)) {
      emergencyShutdown();  // Will not return
    }
  }
  
  // === ERROR REPORTING ===
  if (errorFlags != ERROR_NONE) {
    assertError();
  }
  
  // === SERIAL DATA REPORTING (1s interval) ===
  if (now - lastReportTime >= SERIAL_REPORT_INTERVAL) {
    printDataReport();
    lastReportTime = now;
  }
  
  // === SERIAL COMMAND PROCESSING ===
  processSerialCommands();
  
  // Small delay to prevent busy-waiting
  delay(10);
}

